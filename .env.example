# ===== ShareTube environment (EXAMPLE — no real secrets) =====
# Copy to .env and fill in. NEVER commit the real .env.

ENV=prod
APP_PORT=8989
PUBLIC_BASE_URL=https://sharetube.appswire.ru
# Generate: python -c "import secrets;print(secrets.token_urlsafe(48))"
SECRET_KEY=change_me_generate_a_long_random_value
LOG_LEVEL=INFO
LOG_JSON=true

# ----- database / redis -----
POSTGRES_USER=sharetube
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=sharetube
DATABASE_URL=postgresql+asyncpg://sharetube:change_me_strong_password@postgres:5432/sharetube
DATABASE_URL_SYNC=postgresql+psycopg2://sharetube:change_me_strong_password@postgres:5432/sharetube
REDIS_URL=redis://redis:6379/0

# ----- telegram bot -----
BOT_TOKEN=123456:REPLACE_WITH_BOT_TOKEN
BOT_USERNAME=sharetube_bot
TELEGRAM_USE_WEBHOOK=false
TELEGRAM_WEBHOOK_SECRET=change_me_random
# comma-separated telegram user ids allowed into the admin panel
TELEGRAM_ADMIN_IDS=

# ----- optional local bot api -----
LOCAL_BOT_API_ENABLED=false
LOCAL_BOT_API_BASE=http://telegram-bot-api:8081
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# If the cloud Bot API is unreachable on the host's direct route (e.g. blocked),
# tunnel bot traffic via the outbound SOCKS. Empty = direct. Ignored with Local Bot API.
TELEGRAM_PROXY_URL=socks5://amneziawg:1080

# ----- delivery limits (MB / hours) -----
CLOUD_BOT_SAFE_LIMIT_MB=45
LOCAL_BOT_SAFE_LIMIT_MB=1900
MAX_DOWNLOAD_SIZE_MB=10000
DOWNLOAD_LINK_TTL_HOURS=24

# ----- queue / limits -----
MAX_ACTIVE_JOBS_PER_USER=2
MAX_QUEUED_JOBS_PER_USER=5
MAX_GLOBAL_DOWNLOADS=3
MAX_GLOBAL_TRANSCODES=1
MAX_PLAYLIST_ITEMS=20
JOB_TIMEOUT_MINUTES=120
MAX_URL_LENGTH=2048
PLAYLISTS_ENABLED=false

# ----- storage -----
STORAGE_PROVIDER=local
STORAGE_DIR=/data/storage
TMP_DIR=/data/tmp
MAX_STORAGE_GB=2
DOWNLOAD_RATE_LIMIT_KBPS=0

# ----- s3 (optional, if STORAGE_PROVIDER=s3) -----
S3_ENDPOINT=
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ----- outbound / network routing -----
# Downloads go ONLY through configured routes. proxy failed != try direct.
OUTBOUND_REQUIRED=true
# Primary outbound = AmneziaWG obfuscated WireGuard tunnel (userspace SOCKS, no TUN).
# It bypasses upstream throttling that kills the plain Xray/Reality route.
XRAY_SOCKS_URL=socks5h://amneziawg:1080
XRAY_BACKUP_SOCKS_URL=socks5h://xray:1080
# AmneziaWG client config as base64 (kept out of git). Generate:
#   base64 -w0 your_amnezia.conf
AWG_CONFIG=
# The Xray sidecar (backup route) reads ONE of these (kept out of git):
XRAY_OUTBOUND_URI=
XRAY_CONFIG_JSON=
# Optional per-tool HTTP/SOCKS proxies (usually managed via admin, not here):
YTDLP_PROXY_URL=
GALLERY_DL_PROXY_URL=
DIRECT_DOWNLOAD_PROXY_URL=
NO_PROXY=127.0.0.1,localhost,postgres,redis,xray,telegram-bot-api

# ----- security -----
DOMAIN_ALLOWLIST=
DOMAIN_DENYLIST=
MAX_REDIRECTS=5
RATE_LIMIT_PER_MINUTE=30
ADMIN_SESSION_TTL_HOURS=12
CORS_ORIGINS=https://sharetube.appswire.ru

# ----- monitoring (optional) -----
SENTRY_DSN=
PROMETHEUS_ENABLED=false
